# Copy this file to .env and fill in your own credentials.
# Never commit the real .env file.

# SRT login
KSKILL_SRT_ID=your_srt_id_here
KSKILL_SRT_PASSWORD=your_srt_password_here

# KTX login
KSKILL_KTX_ID=your_ktx_id_here
KSKILL_KTX_PASSWORD=your_ktx_password_here

# Optional: only needed when using --notify telegram for the SRT watcher.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
